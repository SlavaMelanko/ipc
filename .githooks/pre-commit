#!/usr/bin/env bash
# Format + lint gate. Runs on staged C++ files only.
# Enabled automatically by the first CMake configure (see cmake/GitHooks.cmake).
set -euo pipefail

files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(cpp|h)$' || true)

[[ -z "$files" ]] && exit 0

if ! command -v clang-format >/dev/null; then
  echo "pre-commit: clang-format not found" >&2
  exit 1
fi

echo "pre-commit: clang-format --dry-run --Werror"
# shellcheck disable=SC2086
clang-format --dry-run --Werror $files

if command -v clang-tidy >/dev/null; then
  echo "pre-commit: clang-tidy"
  root="$(git rev-parse --show-toplevel)"
  # shellcheck disable=SC2086
  clang-tidy --warnings-as-errors=* $files -- -x c++ -std=c++23 -I"$root/src" \
    -I"$root/build/_deps/cli11-src/include" \
    -I"$root/build/_deps/zlib-ng-build"
else
  echo "pre-commit: skipping clang-tidy (not installed)" >&2
fi
